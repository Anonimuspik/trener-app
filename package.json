{
  "name": "trener-exe",
  "version": "1.0.3",
  "description": "Трекер підготовки до вступу",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "author": "твоє ім'я",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "com.tvoeim.trener",
    "productName": "Trener",
    "files": [
      "main.js",
      "trener1.html",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Anonimuspik",
      "repo": "trener-app"
    }
  }
}
